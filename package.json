{
  "name": "interval-timers",
  "private": true,
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "apps/aerobic",
    "apps/amrap",
    "apps/app",
    "apps/bio-sync-sixty",
    "apps/daily-warmup",
    "apps/emom",
    "apps/gibala-method",
    "apps/japanese-walking",
    "apps/lactate-threshold",
    "apps/landing",
    "apps/power-intervals",
    "apps/programs",
    "apps/tabata",
    "apps/ten-twenty-thirty",
    "apps/timmons",
    "apps/trainer-chat",
    "apps/wingate",
    "apps/bio-sync-sixty/apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w landing",
    "dev:landing": "npm run dev -w landing",
    "build": "npm run build -w landing",
    "build:landing": "npm run build -w landing",
    "lint": "npm run lint -w landing",
    "dev:daily-warmup": "npm run dev -w daily-warmup",
    "build:daily-warmup": "npm run build -w daily-warmup",
    "dev:tabata": "npm run dev -w tabata",
    "build:tabata": "npm run build -w tabata",
    "dev:japanese-walking": "npm run dev -w japanese-walking",
    "build:japanese-walking": "npm run build -w japanese-walking",
    "dev:amrap": "npm run dev -w amrap",
    "dev:amrap:video": "concurrently -n amrap,app -c blue,green \"npm run dev:video -w amrap\" \"npm run dev:app\"",
    "build:amrap": "npm run build -w amrap",
    "dev:aerobic": "npm run dev -w aerobic",
    "build:aerobic": "npm run build -w aerobic",
    "dev:lactate-threshold": "npm run dev -w lactate-threshold",
    "build:lactate-threshold": "npm run build -w lactate-threshold",
    "build:deploy": "turbo run build --filter=landing --filter=daily-warmup --filter=tabata --filter=japanese-walking --filter=aerobic --filter=amrap --filter=lactate-threshold --filter=power-intervals --filter=gibala-method --filter=wingate --filter=timmons --filter=emom --filter=ten-twenty-thirty --filter=bio-sync-sixty --filter=master-clock && node scripts/copy-standalone-apps-to-dist.cjs",
    "preview:deploy": "npm run build:deploy && npm run preview -w landing",
    "dev:power-intervals": "npm run dev -w power-intervals",
    "build:power-intervals": "npm run build -w power-intervals",
    "dev:gibala-method": "npm run dev -w gibala-method",
    "build:gibala-method": "npm run build -w gibala-method",
    "dev:wingate": "npm run dev -w wingate",
    "build:wingate": "npm run build -w wingate",
    "dev:timmons": "npm run dev -w timmons",
    "build:timmons": "npm run build -w timmons",
    "dev:emom": "npm run dev -w emom",
    "build:emom": "npm run build -w emom",
    "dev:ten-twenty-thirty": "npm run dev -w ten-twenty-thirty",
    "build:ten-twenty-thirty": "npm run build -w ten-twenty-thirty",
    "dev:bio-sync-sixty": "npm run dev -w bio-sync-sixty",
    "build:bio-sync-sixty": "npm run build -w bio-sync-sixty",
    "dev:master-clock": "npm run dev -w master-clock",
    "build:master-clock": "npm run build -w master-clock",
    "dev:trainer-chat": "npm run dev -w trainer-chat",
    "build:trainer-chat": "npm run build -w trainer-chat",
    "dev:app": "npm run dev -w app",
    "build:app": "npm run build -w app",
    "env:pull": "vercel env pull .env.local --yes 2>/dev/null || echo '[env:pull] Run vercel link at repo root (Main)'; (cd apps/app && vercel env pull .env.local --yes) 2>/dev/null || echo '[env:pull] Run vercel link in apps/app (App)'; (cd apps/landing && vercel env pull .env.local --yes) 2>/dev/null || echo '[env:pull] Run vercel link in apps/landing (Landing)'; (cd apps/amrap && vercel env pull .env.local --yes) 2>/dev/null || echo '[env:pull] Run vercel link in apps/amrap (AMRAP)'",
    "env:link": "echo 'One-time setup: vercel link in each dir (select matching project): 1) root -> Main 2) apps/app -> App 3) apps/landing -> Landing 4) apps/amrap -> AMRAP'",
    "generate:timer": "node scripts/generate-timer-app.cjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.0",
    "agora-token": "^2.0.5"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "turbo": "^2.8.15"
  }
}