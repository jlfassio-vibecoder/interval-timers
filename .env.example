# For local dev: copy to .env or run npm run env:pull after vercel link.
# For Vercel: use Shared Environment Variables (Team Settings). See docs/SECTION_10_ENV_IMPLEMENTATION.md.
#
# Supabase: HIIT Workout Timers monorepo
# Copy to .env and set values. Do not commit .env.
# Project: https://dgxoyhkqdxarewmanbrq.supabase.co

# Project URL (client and server)
SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co

# Publishable / anon key (client-safe; from Dashboard → Settings → API)
SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Service role key (server-side only; from Dashboard → Settings → API)
# Must be different from anon key. Copy from Dashboard → Settings → API for local dev.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection (migrations, CLI, server-only)
# Format: postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

# DB password (for scripts; prefer DATABASE_URL when possible)
SUPABASE_DB_PASSWORD=your-db-password

# Optional: SUPABASE_ACCESS_TOKEN for CLI if not using supabase login
# SUPABASE_ACCESS_TOKEN=your-access-token

# Programs (central hub) - post-login redirect
# Dev (cross-origin): e.g. http://localhost:3006/account when timer apps use different ports.
# Prod (same-origin): /account or leave empty. See docs/AUTH_ENV_AND_REDIRECTS.md.
# VITE_ACCOUNT_REDIRECT_URL=/account
