---
// Base layout – head from index.html, no Tailwind CDN
import Navigation from '../components/Navigation';
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bio-Sync60: The Bio-Harmonic Handbook</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      ::-webkit-scrollbar { width: 8px; }
      ::-webkit-scrollbar-track { background: #F5F2EB; }
      ::-webkit-scrollbar-thumb { background: #D1D5DB; border-radius: 4px; }
      ::-webkit-scrollbar-thumb:hover { background: #9CA3AF; }
    </style>
    <style is:global>
      @keyframes flow {
        0% { stroke-dashoffset: 1000; opacity: 0; }
        20% { opacity: 1; }
        80% { stroke-dashoffset: 0; opacity: 1; }
        100% { stroke-dashoffset: 0; opacity: 0; }
      }
      @keyframes pulse-light {
        0%, 100% { opacity: 0.1; transform: scale(0.9); }
        50% { opacity: 0.6; transform: scale(1.1); }
      }
      @keyframes wave-anim {
        0%, 100% { height: 10px; opacity: 0.3; }
        50% { height: 40px; opacity: 1; }
      }
      .neural-path {
        stroke-dasharray: 1000;
        stroke-dashoffset: 1000;
        animation: flow 4s ease-in-out infinite;
      }
      .glow-pulse {
        animation: pulse-light 4s ease-in-out infinite;
      }
      .wave-bar {
        width: 3px;
        background: #22d3ee;
        border-radius: 2px;
        animation: wave-anim 2s ease-in-out infinite;
      }
    </style>
  </head>
  <body class="bg-sync-base text-sync-dark font-sans antialiased selection:bg-sync-orange selection:text-white">
    <Navigation client:load />
    <slot />
  </body>
</html>
