# AMRAP With Friends: Supabase (client-safe keys only)
# Copy to .env or .env.local and set values. Never commit .env or .env.local.
# Use only anon/public key here; service_role and DB password are for server-side only.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# After login/create account, redirect to Account page (programs app).
# Local dev: http://localhost:3006/account (programs and amrap on different ports)
# Production (same-origin): use relative path /account
VITE_ACCOUNT_REDIRECT_URL=http://localhost:3006/account

# Fallback if VITE_ACCOUNT_REDIRECT_URL not set
# VITE_HUD_REDIRECT_URL=/account
