                        focus: "High heart rate variance.",
                        exercises: [
                            { qty: "15", move: "Wall Balls", type: "Full Body/Systemic" },
                            { qty: "10", move: "Single-Arm KB Snatches", type: "Power/Dynamic" },
                            { qty: "15", move: "V-Ups", type: "Core" },
                            { qty: "100m", move: "Shuttle Run (or 15 Cal Row)", type: "Monostructural" }
                        ]
                    },
                    {
                        name: "Workout 4: Power Endurance",
                        focus: "Maintaining strength under fatigue.",
                        exercises: [
                            { qty: "8", move: "Dumbbell Deadlifts", type: "Posterior Chain (Light 40%)" },
                            { qty: "8", move: "Dumbbell Floor Press", type: "Upper Body Push" },
                            { qty: "6", move: "Broad Jumps", type: "Plyometrics" },
                            { qty: "12", move: "Mountain Climbers", type: "Core/Systemic" }
                        ]
                    }
                ]
            },
            advanced: {
                id: 'advanced',
                title: 'Advanced Protocols',
                subtitle: '"Max Work Capacity"',
                duration: '20 Minutes',
                goal: 'Negative split execution. Aim to make the final 5 minutes the highest round-density of the workout.',
                colorHex: '#dc2626', // red-600
                chartData: [95, 90, 100, 100], // Intensity, Skill, Pacing Focus, Volume
                workouts: [
                    {
                        name: "Workout 1: The 2026 Benchmark",
                        focus: "High-skill standard test.",
                        exercises: [
                            { qty: "10", move: "Barbell Clusters (40% 1RM)", type: "Functional" },
                            { qty: "12", move: "Toes-to-Bar", type: "Core/Gymnastics" },
                            { qty: "5-8", move: "Depth Jumps", type: "High Intensity Plyo" },
                            { qty: "20", move: "Double Unders", type: "Dynamic Stability" }
                        ]
                    },
                    {
                        name: "Workout 2: Power-Recovery Loop",
                        focus: "Continuous flow under heavy load.",
                        exercises: [
                            { qty: "12", move: "Dual DB Clean & Press", type: "Functional" },
                            { qty: "15", move: "Box Jump Overs", type: "Plyometric/Dynamic" },
                            { qty: "12", move: "Chest-to-Bar Pull-ups", type: "Upper Body Pull" },
                            { qty: "20", move: "Weighted Walking Lunges", type: "Lower Body Push" }
                        ]
                    },
                    {
                        name: "Workout 3: Systemic Fatigue",
                        focus: "Machine cardio vs external load.",
                        exercises: [
                            { qty: "15", move: "Calories Assault/Echo Bike", type: "Monostructural" },
                            { qty: "10", move: "Sandbag/Medball Cleans", type: "Functional" },
                            { qty: "12", move: "Burpee Box Jumps", type: "Dynamic Conditioning" },
                            { qty: "15", move: "Hollow Rocks", type: "Core" }
                        ]
                    },
                    {
                        name: "Workout 4: The Antagonistic Finale",
                        focus: "Strict gymnastics & heavy legs.",
                        exercises: [
                            { qty: "12", move: "Front Squats (40% 1RM)", type: "Lower Body Push" },
                            { qty: "10", move: "Strict HSPU or Pike Push-ups", type: "Upper Body Push" },
                            { qty: "12", move: "Alt. Dumbbell Snatches", type: "Systemic" },
                            { qty: "10", move: "Strict Toes-to-Bar", type: "Core/Passive Recovery" }
                        ]
                    }
                ]
            }
        };

        // --- 2. State Management & Core Logic ---
        const app = {
            currentTier: null,
            chartInstance: null,

            init() {
                this.initChart();
                this.setTier('beginner'); // Default state
            },

            setTier(tierKey) {
                if(this.currentTier === tierKey) return; // Prevent redundant updates
                this.currentTier = tierKey;
                const data = protocolData[tierKey];

                this.updateUIButtons(tierKey);
                this.updateFeedHeaders(data);
                this.renderWorkouts(data);
                this.updateChart(data);
            },

            updateUIButtons(activeKey) {
                const buttons = ['beginner', 'intermediate', 'advanced'];
                buttons.forEach(key => {
                    const btn = document.getElementById(`btn-${key}`);
                    // Reset styling
                    btn.classList.remove('active-beginner', 'active-intermediate', 'active-advanced', 'text-white', 'border-transparent');
                    btn.classList.add('bg-white', 'text-stone-700', 'border-stone-200');
                    
                    // Apply active styling
                    if (key === activeKey) {
                        btn.classList.remove('bg-white', 'text-stone-700', 'border-stone-200');
                        btn.classList.add(`active-${key}`);
                    }
                });
            },

            updateFeedHeaders(data) {
                document.getElementById('feed-title').textContent = data.title;
                document.getElementById('feed-subtitle').textContent = data.subtitle;
                document.getElementById('feed-duration').textContent = data.duration;
                document.getElementById('feed-goal').textContent = data.goal;
            },

            renderWorkouts(data) {
                const container = document.getElementById('workout-container');
                container.innerHTML = ''; // Clear existing

                data.workouts.forEach((workout, index) => {
                    const card = document.createElement('div');
                    card.className = 'workout-card bg-white border border-stone-200 rounded-xl overflow-hidden flex flex-col';
                    
                    // Create exercise list items
                    const exercisesHtml = workout.exercises.map(ex => `
                        <li class="flex items-start gap-3 py-2 border-b border-stone-100 last:border-0">
                            <span class="font-bold text-stone-900 bg-stone-100 px-2 py-0.5 rounded text-sm min-w-[36px] text-center">${ex.qty}</span>
                            <div>
                                <span class="block text-sm font-semibold text-stone-800">${ex.move}</span>
                                <span class="block text-[11px] uppercase tracking-wider text-stone-500 font-medium">${ex.type}</span>
                            </div>
                        </li>
                    `).join('');

                    card.innerHTML = `
                        <div class="p-4 bg-stone-50 border-b border-stone-200">
                            <h4 class="font-bold text-lg text-stone-900 leading-tight">${workout.name}</h4>
                            <p class="text-xs text-stone-500 mt-1 italic border-l-2 border-stone-300 pl-2">${workout.focus}</p>
                        </div>
                        <div class="p-4 flex-grow bg-white">
                            <ul class="space-y-1">
                                ${exercisesHtml}
                            </ul>
                        </div>
                    `;
                    container.appendChild(card);
                });
            },

            // --- 3. Chart Initialization & Updating ---
            initChart() {
                const ctx = document.getElementById('demandChart').getContext('2d');
                
                // Chart.js global defaults for typography
                Chart.defaults.font.family = 'Inter, sans-serif';
                Chart.defaults.color = '#78716c'; // stone-500

                this.chartInstance = new Chart(ctx, {
                    type: 'radar',
                    data: {
                        labels: ['Intensity (HR%)', 'Movement Skill', 'Pacing Focus', 'Total Volume'],
                        datasets: [{
                            label: 'Demands',
                            data: [0,0,0,0], // Initialized empty, updated immediately
                            backgroundColor: 'rgba(0,0,0,0)',
                            borderColor: '#000',
                            borderWidth: 2,
                            pointBackgroundColor: '#000',
                            pointBorderColor: '#fff',
                            pointHoverBackgroundColor: '#fff',
                            pointHoverBorderColor: '#000',
                            pointRadius: 4,
                            pointHoverRadius: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            r: {
                                angleLines: { color: 'rgba(0,0,0,0.05)' },
                                grid: { color: 'rgba(0,0,0,0.05)' },
                                pointLabels: {
                                    font: { size: 11, weight: '600' },
                                    color: '#57534e' // stone-600
                                },
                                ticks: {
                                    display: false, // Hide numeric scale for cleaner look
                                    min: 0,
                                    max: 100
                                }
                            }
                        },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: 'rgba(28, 25, 23, 0.9)', // stone-900
                                titleFont: { size: 13, weight: 'bold' },
                                bodyFont: { size: 12 },
                                padding: 10,
                                cornerRadius: 8,
                                displayColors: false,
                                callbacks: {
                                    label: function(context) {
                                        return `Relative Demand: ${context.raw}/100`;
                                    }
                                }
                            }
                        }
                    }
                });
            },

            updateChart(data) {
                if(!this.chartInstance) return;
                
                const dataset = this.chartInstance.data.datasets[0];
                
                // Animate to new data
                dataset.data = data.chartData;
                
                // Update styling based on tier colors
                // Adding transparency to the hex color for the fill
                let r=0, g=0, b=0;
                if(data.colorHex === '#16a34a') { r=22; g=163; b=74; } // Green
                if(data.colorHex === '#d97706') { r=217; g=119; b=6; } // Amber
                if(data.colorHex === '#dc2626') { r=220; g=38; b=38; } // Red
                
                dataset.backgroundColor = `rgba(${r}, ${g}, ${b}, 0.2)`;
                dataset.borderColor = data.colorHex;
                dataset.pointBackgroundColor = data.colorHex;
                dataset.pointHoverBorderColor = data.colorHex;

                this.chartInstance.update();
            }
        };

        // Bootstrap App
        document.addEventListener('DOMContentLoaded', () => {
            app.init();
        });

    </script>
</body>
</html>