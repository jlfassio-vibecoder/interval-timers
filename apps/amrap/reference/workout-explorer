                workouts: [
                    {
                        name: "Workout 1: The Classic Hybrid",
                        focus: "Standard hybrid blend.",
                        exercises: [
                            { qty: "10", move: "Dumbbell Thrusters", type: "Functional/Multi-joint" },
                            { qty: "12", move: "Burpees", type: "Bodyweight Conditioning" },
