---
// Static Footer - Pure HTML for SEO
import AdminFooterButton from '../react/AdminFooterButton';
---

<footer class="relative z-10 border-t border-white/10 bg-black/80 py-12 backdrop-blur-xl md:py-16">
  <div
    class="mx-auto flex max-w-7xl flex-col items-start justify-between gap-8 px-6 md:flex-row md:items-end"
  >
    <div>
      <div class="mb-4 font-heading text-xl font-bold tracking-tighter text-white md:text-2xl">
        AI FITCOPILOT
      </div>
    </div>
    <div class="flex flex-wrap items-center gap-6 md:gap-8">
      <a
        href="/privacy"
        class="text-xs font-bold uppercase tracking-widest text-gray-400 transition-colors hover:text-orange-light"
        >Privacy</a
      >
      <a
        href="/terms"
        class="text-xs font-bold uppercase tracking-widest text-gray-400 transition-colors hover:text-orange-light"
        >Terms</a
      >
      <a
        href="#"
        class="text-xs font-bold uppercase tracking-widest text-gray-400 transition-colors hover:text-orange-light"
        >Twitter</a
      >
      <AdminFooterButton client:only="react" />
    </div>
  </div>
</footer>
