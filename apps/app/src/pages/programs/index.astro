---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StandaloneNav from '../../components/react/StandaloneNav';
import { getPublishedPrograms } from '../../lib/supabase/public/program-service';
import { getAllZonesServer } from '../../lib/supabase/admin/server-equipment';
import ProgramPrescriptionEngine from '../../components/react/public/ProgramPrescriptionEngine';

const availablePrograms = await getPublishedPrograms();
const zones = await getAllZonesServer();
const zonesForClient = zones.map((z) => ({ id: z.id, name: z.name }));
---

<BaseLayout title="Programs | AI Fitcopilot | AI-Powered Hypertrophy & Tactical Workout Programs.">
  <div
    class="relative min-h-screen overflow-x-hidden text-white selection:bg-orange-light selection:text-black"
  >
    <StandaloneNav client:load pathname={Astro.url.pathname} />
    <main class="pt-24">
      <ProgramPrescriptionEngine
        client:load
        availablePrograms={availablePrograms}
        zones={zonesForClient}
      />
    </main>
  </div>
</BaseLayout>
