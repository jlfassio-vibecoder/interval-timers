# Copy to .env.local and fill in values.
# Required for local development (see PRE_PR_CHECKLIST.md).

# Cross-origin logout propagation (dev only): AMRAP logout URL to clear session there.
# Dev: http://localhost:5177/amrap/logout. Leave unset in production (same-origin).
# PUBLIC_AMRAP_LOGOUT_URL=http://localhost:5177/amrap/logout

# Supabase (required) - HIIT Workout Timer project (same as AMRAP auth).
# Use PUBLIC_* here, OR set VITE_SUPABASE_* in monorepo root .env (shared with AMRAP).
# URL must be https://<project-ref>.supabase.co
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
# Optional: for cross-subdomain auth (Blueprint §9). Set to .yourdomain.com so sb-access-token
# is readable by app.yourdomain.com, yourdomain.com, etc. Leave unset for same-origin or localhost.
# PUBLIC_AUTH_COOKIE_DOMAIN=.hiitworkouttimer.com
# SUPABASE_SERVICE_ROLE_KEY=  # Required for server/API. Get from Dashboard → Settings → API → service_role.
# SUPABASE_ACCESS_TOKEN=     # Optional: for Supabase CLI (link); copy to .env.local
# SUPABASE_DB_PASSWORD=      # Required for supabase db push. Get from Dashboard → Project Settings → Database (reset if needed)

# App URL (for pricing CTAs when Stripe links not set). Default: https://app.aiworkoutgenerator.com
# PUBLIC_APP_URL=

# Stripe payment links (pricing section). Premium $11.99 default: https://buy.stripe.com/dRm6oHcW3gW19RZ6qlgnK00
# PUBLIC_STRIPE_PAYMENT_LINK_PREMIUM=
# PUBLIC_STRIPE_PAYMENT_LINK_PRO=
# PUBLIC_STRIPE_PAYMENT_LINK_ELITE=
# PUBLIC_STRIPE_PAYMENT_LINK_COACH=
# PUBLIC_STRIPE_PAYMENT_LINK_COACH_PRO=

# Optional: for specific features
# GEMINI_API_KEY=           # Deep dive generation, Veo video generation (Generate with Gemini)
# RUNWAYML_API_SECRET=      # Admin exercise video generation (Runway ML, Generate with Runway)

# Firebase Hosting / scripts/set-env.sh (optional; for Firebase App Hosting build)
# Get from Firebase Console → Project settings → General / Your apps. Do not commit real values.
# PUBLIC_FIREBASE_API_KEY=
# PUBLIC_FIREBASE_AUTH_DOMAIN=
# PUBLIC_FIREBASE_PROJECT_ID=
# PUBLIC_FIREBASE_STORAGE_BUCKET=
# PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# PUBLIC_FIREBASE_APP_ID=
# PUBLIC_RECAPTCHA_ENTERPRISE_SITE_KEY=   # reCAPTCHA Enterprise (Console → APIs)
# PUBLIC_GEMINI_API_KEY=                 # If using client-side Gemini (prefer server-side GEMINI_API_KEY)

# --- Vercel (production) ---
# In Vercel: Project → Settings → Environment Variables. Add to EACH project (Root, App):
#   SUPABASE_URL            = https://<project-ref>.supabase.co  (or VITE_SUPABASE_URL / PUBLIC_SUPABASE_URL)
#   SUPABASE_ANON_KEY       = anon JWT (Dashboard → API)         (or VITE_ / PUBLIC_ variants)
#   SUPABASE_SERVICE_ROLE_KEY = service_role JWT — keep secret, server-only.
# See docs/SUPABASE_ENV.md. Apply to Production (and Preview if needed).
