{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "20.x",
    "npm": ">=10.8.0"
  },
  "scripts": {
    "dev": "npx astro dev --port 3006",
    "prebuild": "npm install --include=optional --force @rollup/rollup-linux-x64-gnu 2>/dev/null || npm install --include=optional --force",
    "copy:favicon": "node scripts/copy-favicon.js",
    "build": "npm run copy:favicon && astro build",
    "preview": "astro preview",
    "start": "node server.js",
    "astro": "astro",
    "prepare": "husky",
    "lint": "eslint . --ext .ts,.tsx,.astro",
    "lint:fix": "eslint . --ext .ts,.tsx,.astro --fix",
    "format": "prettier --write \"**/*.{ts,tsx,astro,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,astro,json,md,css}\"",
    "type-check": "tsc --noEmit",
    "verify:quick": "npm run lint && npm run type-check && npm run test",
    "verify:all": "npm run lint && npm run type-check && npm run build",
    "verify:deploy": "npm run verify:all && npm run security:scan",
    "security:scan": "node scripts/verify-security.js",
    "check-env": "node scripts/check-env.js",
    "db:push": "node scripts/db-push.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google-cloud/vertexai": "^1.10.0",
    "@google/genai": "^1.29.0",
    "@interval-timers/analytics": "*",
    "@interval-timers/auth-ui": "*",
    "@interval-timers/handoff": "*",
    "@runwayml/sdk": "^3.11.0",
    "@supabase/auth-helpers-react": "^0.15.0",
    "@supabase/auth-ui-react": "^0.4.7",
    "@supabase/auth-ui-shared": "^0.1.8",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.97.0",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "devalue": "^5.6.2",
    "dompurify": "^3.3.1",
    "es-module-lexer": "^1.7.0",
    "express": "^4.22.1",
    "framer-motion": "^12.23.24",
    "fuse.js": "^7.0.0",
    "google-auth-library": "^10.5.0",
    "jsonrepair": "^3.13.2",
    "lucide-react": "^0.553.0",
    "marked": "^17.0.1",
    "piccolore": "^0.1.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.13.0",
    "react-select": "^5.10.2",
    "recharts": "^3.7.0",
    "sanitize-html": "^2.17.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.5"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.59.0"
  },
  "overrides": {
    "fast-xml-parser": ">=5.3.4",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-replace": "^6.0.2",
    "@rollup/pluginutils": "^5.1.4",
    "@apideck/better-ajv-errors": {
      "ajv": "^8.0.0"
    }
  },
  "devDependencies": {
    "@astrojs/node": "^9.5.2",
    "@astrojs/react": "^5.0.0",
    "@astrojs/tailwind": "^6.0.2",
    "@astrojs/vercel": "^9.0.4",
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.14.0",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sanitize-html": "^2.16.0",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@vite-pwa/astro": "^1.2.0",
    "astro": "^5.16.15",
    "astro-eslint-parser": "^1.2.2",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.2",
    "eslint-plugin-astro": "^1.5.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.2",
    "vitest": "^3.2.4"
  }
}
