# Agora RTC App ID (from Agora Console -> Project Settings)
VITE_AGORA_APP_ID=

# Agora Token (required if App Certificate is enabled in Agora Console)
# If your project uses Token authentication, you must provide a valid token.
# Generate tokens via: Agora Console -> Project -> App Certificate -> Generate temp token
# Or deploy a token server: https://docs.agora.io/en/video-calling/token-authentication/deploy-token-server
# Leave empty only when App Certificate is DISABLED (testing mode).
VITE_AGORA_TOKEN=
