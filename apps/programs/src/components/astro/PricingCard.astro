---
import type { PricingPlan } from '../../data/pricing';

interface Props {
  plan: PricingPlan;
}

const { plan } = Astro.props;
---

<div
  class:list={[
    'relative flex min-h-full flex-col rounded-2xl border p-6 backdrop-blur-md transition-all duration-300 md:p-8',
    plan.popular
      ? 'border-orange-light/50 bg-orange-light/5 shadow-orange-light/10 shadow-lg'
      : 'border-white/10 bg-white/5',
  ]}
  data-cta={`pricing-${plan.id}`}
>
  {
    plan.popular && (
      <div class="absolute -top-3 right-6 rounded-full bg-orange-light px-3 py-1 text-xs font-bold uppercase tracking-wider text-black">
        Most Popular
      </div>
    )
  }
  <div class="mb-6">
    <h3 class="font-heading text-2xl font-bold text-white md:text-3xl">{plan.name}</h3>
    <p class="mt-1 text-sm text-gray-400">{plan.description}</p>
    <div class="mt-4 flex flex-wrap items-baseline gap-2">
      {
        plan.originalPrice != null && (
          <span class="text-xl text-gray-500 line-through">${plan.originalPrice}</span>
        )
      }
      <span class="text-4xl font-bold text-white md:text-5xl">${plan.price}</span>
      <span class="text-lg text-gray-400">/{plan.period}</span>
    </div>
  </div>
  <ul class="mb-8 flex-1 space-y-3 text-sm text-gray-300">
    {
      plan.features.map((feature) => (
        <li class="flex items-start gap-3">
          <svg
            class="mt-0.5 h-5 w-5 shrink-0 text-orange-light"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M5 13l4 4L19 7"
            />
          </svg>
          <span>{feature}</span>
        </li>
      ))
    }
  </ul>
  <div class="mt-auto">
    {
      plan.ctaLink ? (
        <a
          href={plan.ctaLink}
          class="block w-full rounded-xl py-3 text-center text-sm font-semibold uppercase tracking-wider transition-colors"
          class:list={[
            plan.ctaVariant === 'primary'
              ? 'hover:bg-orange-light/90 bg-orange-light text-black'
              : 'border-orange-light/50 hover:bg-orange-light/10 border-2 text-orange-light hover:border-orange-light',
          ]}
        >
          {plan.ctaText}
        </a>
      ) : (
        <span
          class="block w-full rounded-xl py-3 text-center text-sm font-semibold uppercase tracking-wider"
          class:list={[
            plan.ctaVariant === 'primary'
              ? 'bg-orange-light text-black'
              : 'border-2 border-white/20 text-gray-400',
          ]}
        >
          {plan.ctaText}
        </span>
      )
    }
  </div>
</div>
