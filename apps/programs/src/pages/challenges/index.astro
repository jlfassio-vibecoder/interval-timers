---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StandaloneNav from '../../components/react/StandaloneNav';
import { getPublishedChallenges } from '@/lib/supabase/public/challenge-service';
import { getAllZonesServer } from '../../lib/supabase/admin/server-equipment';
import ChallengeCatalog from '../../components/react/public/ChallengeCatalog';

const availableChallenges = await getPublishedChallenges();
const zones = await getAllZonesServer();
const zonesForClient = zones.map((z) => ({ id: z.id, name: z.name }));
---

<BaseLayout
  title="Challenges | AI Fitcopilot | AI-Powered Hypertrophy & Tactical Workout Programs."
>
  <div
    class="relative min-h-screen overflow-x-hidden text-white selection:bg-orange-light selection:text-black"
  >
    <StandaloneNav client:load pathname={Astro.url.pathname} />
    <main class="pt-24">
      <ChallengeCatalog
        client:load
        availableChallenges={availableChallenges}
        zones={zonesForClient}
      />
    </main>
  </div>
</BaseLayout>
