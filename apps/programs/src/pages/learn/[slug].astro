---
/**
 * @license
 * SPDX-License-Identifier: Apache-2.0
 *
 * Learning Center deep dive page. Serves the same Science & Mastery content as
 * /exercises/[slug]/learn but with back link to /learn. Canonical URL remains
 * /exercises/[slug]/learn (set in inject-deep-dive-meta).
 */
import { randomBytes } from 'node:crypto';
import { getGeneratedExerciseBySlug } from '@/lib/supabase/public/generated-exercise-service';
import { normalizeMathSymbols } from '@/lib/normalize-math-symbols';
import { prepareDeepDiveDocument } from '@/lib/prepare-deep-dive-document';
import { sanitizeDeepDiveHtml } from '@/lib/sanitize-deep-dive-html';

export const prerender = false;

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/learn');
}

// Fetch exercise (allow pending exercises for preview/deep dive access)
const exercise = await getGeneratedExerciseBySlug(slug, false);

if (!exercise) {
  return Astro.redirect('/404');
}

const { deepDiveHtmlContent } = exercise;

if (deepDiveHtmlContent) {
  const sanitized = sanitizeDeepDiveHtml(deepDiveHtmlContent);
  const withNormalizedMath = normalizeMathSymbols(sanitized, { htmlSafe: true });
  const baseUrl = Astro.site?.href?.replace(/\/$/, '') || new URL(Astro.request.url).origin;
  const nonce = randomBytes(16).toString('base64');
  const metaInput = {
    exerciseName: exercise.exerciseName,
    slug,
    baseUrl,
    imageUrl: exercise.imageUrl ?? '',
    performanceCues: exercise.biomechanics?.performanceCues ?? [],
    complexityLevel: exercise.complexityLevel,
    nonce,
    sources: exercise.sources ?? [],
    backHref: '/learn',
    backLinkLabel: 'Back to Learning Center',
  };
  const prepared = prepareDeepDiveDocument(withNormalizedMath, metaInput);
  const csp = `default-src 'self'; script-src 'self' 'nonce-${nonce}' https://cdn.tailwindcss.com https://cdn.jsdelivr.net https://unpkg.com; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https:; font-src 'self' https:; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'none'`;
  return new Response(prepared, {
    headers: {
      'Content-Type': 'text/html; charset=utf-8',
      'Content-Security-Policy': csp,
      'X-Content-Type-Options': 'nosniff',
    },
  });
}

return Astro.redirect('/learn');
---
