---
/**
 * @license
 * SPDX-License-Identifier: Apache-2.0
 *
 * Public Exercise Detail Page
 * Displays approved generated exercises with the "Iceberg Method" layout.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import StandaloneNav from '../../components/react/StandaloneNav';
import Breadcrumbs from '../../components/astro/Breadcrumbs.astro';
import { getGeneratedExerciseBySlug } from '@/lib/supabase/public/generated-exercise-service';
import { getCurrentUserFromRequest } from '@/lib/supabase/admin/auth';
import { EXERCISE_LABELS } from '@/lib/labels/exercises';
import GeneratedExerciseDetail from '../../components/react/GeneratedExerciseDetail';

export const prerender = false;

const slug = Astro.params.slug;
let exercise = null;
let notFound = false;

if (!slug) {
  notFound = true;
} else {
  try {
    // Public page: only approved exercises visible (avoids exposing pending/rejected via service role)
    exercise = await getGeneratedExerciseBySlug(slug, true);
    // Creator preview: if not found and user is authenticated, allow viewing own pending exercise
    if (!exercise) {
      const user = await getCurrentUserFromRequest(Astro.request, Astro.cookies);
      if (user) {
        const pending = await getGeneratedExerciseBySlug(slug, false);
        if (pending && pending.generatedBy === user.uid) {
          exercise = pending;
        }
      }
    }
    if (!exercise) {
      notFound = true;
    }
  } catch (error) {
    if (import.meta.env.DEV) {
      const message = error instanceof Error ? error.message : 'Unknown error';
      console.error('[exercises/[slug]] Error fetching exercise:', message);
    }
    notFound = true;
  }
}

if (notFound) {
  Astro.response.status = 404;
}

const pageTitle = exercise
  ? `${exercise.exerciseName} | AI Fitcopilot | AI-Powered Hypertrophy & Tactical Workout Programs.`
  : 'Exercise Not Found | AI Fitcopilot | AI-Powered Hypertrophy & Tactical Workout Programs.';

const pageDescription = exercise
  ? `Learn the biomechanics of ${exercise.exerciseName}. Performance cues, common mistakes, and detailed analysis.`
  : 'Exercise not found';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div
    class="relative min-h-screen overflow-x-hidden text-white selection:bg-orange-light selection:text-black"
  >
    <StandaloneNav client:load pathname={Astro.url.pathname} />
    {
      notFound ? (
        <div class="mx-auto max-w-4xl px-4 py-20 text-center">
          <h1 class="mb-4 font-heading text-2xl font-bold text-white md:text-3xl">
            Exercise not found
          </h1>
          <p class="mb-6 text-white/70">
            This exercise may not be published yet or the link is invalid.
          </p>
          <a
            href="/"
            class="inline-flex items-center gap-2 rounded-lg bg-orange-light px-5 py-3 font-bold uppercase tracking-wider text-black transition hover:bg-white"
          >
            Go Home
          </a>
        </div>
      ) : exercise ? (
        <>
          <div class="pt-24">
            <Breadcrumbs
              items={[
                { label: 'Home', href: '/' },
                { label: EXERCISE_LABELS.section, href: '/exercises' },
                { label: exercise.exerciseName },
              ]}
            />
          </div>
          <div class="relative">
            {/* Indexable content for crawlers (sr-only so visible UI stays from React) */}
            <div class="sr-only">
              <h1>{exercise.exerciseName}</h1>
              <p>{pageDescription}</p>
            </div>
            {/* Navigation Overlay */}
            <div class="absolute left-0 top-0 z-20 flex w-full items-center justify-between p-4 md:p-6">
              <a
                href="/exercises"
                class="inline-flex items-center gap-2 rounded-full bg-black/40 px-4 py-2 text-sm font-medium text-white backdrop-blur-md transition hover:bg-black/60"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="m15 18-6-6 6-6" />
                </svg>
                {EXERCISE_LABELS.backLink}
              </a>

              {exercise.deepDiveHtmlContent && (
                <a
                  href={`/exercises/${exercise.slug}/learn`}
                  class="inline-flex items-center gap-2 rounded-full bg-orange-light px-4 py-2 text-sm font-bold uppercase tracking-wider text-black shadow-lg shadow-[#ffbf00]/20 transition hover:bg-white hover:shadow-[#ffbf00]/40"
                >
                  Science & Mastery
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
                  </svg>
                </a>
              )}
            </div>
            <GeneratedExerciseDetail client:only="react" exercise={exercise} isAdmin={false} />
          </div>
        </>
      ) : null
    }
  </div>
</BaseLayout>
