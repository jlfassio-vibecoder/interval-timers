  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "query",
          "key": "protocol",
          "value": "mindful"
        }
      ],
      "destination": "/japanese-walking",
      "permanent": true
    },
    {
      "source": "/",
      "has": [
        {
          "type": "query",
          "key": "protocol",
          "value": "tabata"
        }
      ],
      "destination": "/tabata-timer",
      "permanent": true
    },
    {
      "source": "/",
      "has": [
